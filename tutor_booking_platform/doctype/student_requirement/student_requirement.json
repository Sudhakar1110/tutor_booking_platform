      "in_list_view": "1 "
    },
    {
      "fieldname": "subject",
      "fieldtype": "Link",
      "label": "Subject",
      "options": "Subject",
      "reqd": 1,
      "in_list_view": "1 "
    },
    {
      "fieldname": "requirement_title",
      "fieldtype": "Data",
      "label": "Requirement Title",
      "reqd": "1 "
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\\nMatched\\nClosed",
      "default": "Open",
      "in_list_view": "1 "
    },
    {
      "fieldname": "preferred_mode",
      "fieldtype": "Select",
      "label": "Preferred Mode",
      "options": "Online\\nOffline\\nBoth"
    },
    {
      "fieldname": "preferred_gender",
      "fieldtype": "Select",
      "label": "Preferred Tutor Gender",
      "options": "Any\\nMale\\nFemale"
    },
    {
      "fieldname": "budget_per_hour",
      "fieldtype": "Currency",
      "label": "Budget Per Hour (INR)"
    },
    {
      "fieldname": "preferred_days",
      "fieldtype": "Data",
      "label": "Preferred Days"
    },
    {
      "fieldname": "description",
      "fieldtype": "Text Editor",
      "label": "Detailed Description"
    },
    {
      "fieldname": "location",
      "fieldtype": "Data",
      "label": "Preferred Location / Area"
    },
    {
      "fieldname": "urgency",
      "fieldtype": "Select",
      "label": "Urgency",
      "options": "Low\\nMedium\\nHigh\\nImmediate",
      "default": "Medium"
    },
    {
      "fieldname": "requirement_date",
      "fieldtype": "Date",
      "label": "Requirement Date"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1,
      "permlevel": 0
