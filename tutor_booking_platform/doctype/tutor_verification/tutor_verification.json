{
  "doctype": "DocType",
  "name": "Tutor Verification",
  "module": "Tutor Booking Platform",
  "custom": 0,
  "is_submittable": 0,
  "is_child_table": 0,
  "istable": 0,
  "track_changes": 1,
  "track_seen": 1,
