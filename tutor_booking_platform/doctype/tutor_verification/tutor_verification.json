    {
      "fieldname": "verified_by",
      "fieldtype": "Link",
      "label": "Verified By",
      "options": "User",
      "read_only": "1 "
    },
    {
      "fieldname": "id_proof_type",
      "fieldtype": "Select",
      "label": "ID Proof Type",
      "options": "Aadhaar\\nPAN Card\\nPassport\\nVoter ID\\nDriving License"
    },
    {
      "fieldname": "id_proof_number",
      "fieldtype": "Data",
      "label": "ID Proof Number"
    },
    {
      "fieldname": "id_proof_document",
      "fieldtype": "Attach",
      "label": "ID Proof Document"
    },
    {
      "fieldname": "verification_date",
      "fieldtype": "Date",
      "label": "Verification Date"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Text Editor",
      "label": "Remarks / Notes"
    },
    {
      "fieldname": "rejection_reason",
      "fieldtype": "Text",
      "label": "Rejection Reason"
    }
