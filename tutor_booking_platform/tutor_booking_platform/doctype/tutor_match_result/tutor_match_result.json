{
  "doctype": "DocType",
  "name": "Tutor Match Result",
  "module": "Tutor Booking Platform",
  "custom": 0,
  "is_submittable": 0,
  "is_child_table": 0,
  "istable": 0,
  "track_changes": 1,
  "track_seen": 1,
  "autoname": "naming_series:",
  "naming_rule": "By naming series",
  "title_field": "name",
  "search_fields": "",
  "allow_copy": 1,
  "allow_import": 1,
  "allow_rename": 0,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "TMRS-.YYYY.-.####",
      "reqd": 0,
      "in_list_view": 0,
      "set_only_once": 1
    },
    {
      "fieldname": "sb_match_details",
      "fieldtype": "Section Break",
      "label": "Match Details"
    },
    {
      "fieldname": "search_request",
      "fieldtype": "Link",
      "label": "Search Request",
      "options": "Tutor Search Request",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "tutor_profile",
      "fieldtype": "Link",
      "label": "Tutor Profile",
      "options": "Tutor Profile",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "cb_znybjh",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "match_score",
      "fieldtype": "Float",
      "label": "Match Score (%)",
      "precision": 2,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Suggested\nShortlisted\nContacted\nBooked\nRejected",
      "default": "Suggested",
      "in_list_view": 1
    },
    {
      "fieldname": "sb_tutor_details_(fetched)",
      "fieldtype": "Section Break",
      "label": "Tutor Details (Fetched)"
    },
    {
      "fieldname": "tutor_name",
      "fieldtype": "Data",
      "label": "Tutor Name",
      "fetch_from": "tutor_profile.tutor_name",
      "read_only": 1
    },
    {
      "fieldname": "hourly_rate",
      "fieldtype": "Currency",
      "label": "Rate Per Hour",
      "fetch_from": "tutor_profile.hourly_rate",
      "read_only": 1
    },
    {
      "fieldname": "cb_tkt5tv",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "average_rating",
      "fieldtype": "Float",
      "label": "Rating",
      "fetch_from": "tutor_profile.average_rating",
      "read_only": 1
    },
    {
      "fieldname": "match_date",
      "fieldtype": "Date",
      "label": "Match Date"
    },
    {
      "fieldname": "student_notes",
      "fieldtype": "Text",
      "label": "Student Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1,
      "permlevel": 0
    },
    {
      "role": "Tutor Booking Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 0,
      "permlevel": 0
    },
    {
      "role": "Tutor Booking Operator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 0,
      "amend": 0,
      "permlevel": 0
    },
    {
      "role": "Tutor",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 0,
      "cancel": 0,
      "amend": 0,
      "permlevel": 0
    },
    {
      "role": "Student",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 0,
      "cancel": 0,
      "amend": 0,
      "permlevel": 0
    }
  ],
  "links": [],
  "actions": [],
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "field_order": [
    "naming_series",
    "sb_match_details",
    "search_request",
    "tutor_profile",
    "cb_znybjh",
    "match_score",
    "status",
    "sb_tutor_details_(fetched)",
    "tutor_name",
    "hourly_rate",
    "cb_tkt5tv",
